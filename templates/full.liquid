<div class="layout layout--stretch-x">
  <div class="frame" style="width: 100%; text-align: center;">
    {% if image_url_full %}
      <img class="visible portrait:hidden" src="{{ image_url_full }}" style="width: 100%; height: auto;" />
    {% endif %}
    {% if image_url_full_portrait %}
      <img class="hidden portrait:visible" src="{{ image_url_full_portrait }}" style="width: 100%; height: auto;" />
    {% endif %}
    {% unless image_url_full or image_url_full_portrait %}
      <span class="value">No image yet</span>
    {% endunless %}
  </div>
</div>
